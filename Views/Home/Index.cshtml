@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .dashboard {
        padding: 40px;
    }

    .header {
        margin-bottom: 30px;
    }

        .header h1 {
            margin: 0;
            color: #333;
        }

        .header p {
            color: #777;
        }

    .cards {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }

    .card {
        flex: 1;
        min-width: 250px;
        background: #fff;
        border-radius: 15px;
        padding: 20px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .card:hover {
            transform: translateY(-5px);
        }

        .card h3 {
            margin-bottom: 10px;
            color: #444;
        }

        .card p {
            color: #777;
            font-size: 14px;
        }

    .btn {
        display: inline-block;
        margin-top: 15px;
        padding: 8px 15px;
        background: #7a5cff;
        color: white;
        border-radius: 8px;
        text-decoration: none;
    }

        .btn:hover {
            background: #6848e0;
        }
</style>

<div class="dashboard">
    <div class="header">
        <h1>Dulce Gestión 🍰</h1>
        <p>Sistema administrativo de la panadería</p>
    </div>

    <div class="cards">
        <div class="card">
            <h3>👤 Usuarios</h3>
            <p>Gestiona los empleados del sistema</p>
            <a href="/User" class="btn">Administrar</a>
        </div>

