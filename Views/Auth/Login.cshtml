@{
    ViewData["Title"] = "Login";
}

<style>
    body {
        margin: 0;
        height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(120deg, #f6f9fc, #e9eff5);
    }

    .login-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 80vh;
    }
    .card {
        width: 350px;
        padding: 35px;
        background: #ffffff;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        text-align: center;
    }

        .card h2 {
            margin-bottom: 10px;
            color: #333;
        }

        .card p {
            margin-bottom: 25px;
            color: #888;
            font-size: 14px;
        }

    .input-group {
        text-align: left;
        margin-bottom: 15px;
    }

        .input-group label {
            font-size: 13px;
            color: #555;
        }

        .input-group input {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            border-radius: 8px;
            border: 1px solid #ddd;
            outline: none;
            transition: 0.3s;
        }

            .input-group input:focus {
                border-color: #7a5cff;
                box-shadow: 0 0 0 2px rgba(122,92,255,0.1);
            }

    .btn {
        width: 100%;
        padding: 10px;
        margin-top: 10px;
        background: #7a5cff;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.3s;
        font-weight: 500;
    }

        .btn:hover {
            background: #6848e0;
        }

    .error {
        margin-top: 15px;
        font-size: 13px;
        color: #e74c3c;
    }
</style>

<div class="login-wrapper">
	<div class="card">
    <h2>Bienvenida</h2>
    <p>Ingresa tus datos para continuar</p>

    <form method="post">
        <div class="input-group">
            <label>Usuario</label>
            <input type="text" name="username" required />
        </div>

        <div class="input-group">
            <label>Contraseña</label>
            <input type="password" name="password" required />
        </div>

        <button class="btn" type="submit">Entrar</button>
    </form>

    <div class="error">@ViewBag.Error</div>
  </div>
</div>