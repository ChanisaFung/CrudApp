@model List<CrudApp.Models.User>

<style>
    body {
        background: #fff0f5;
        font-family: 'Segoe UI', sans-serif;
    }

    .card {
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        width: 90%;
        margin: 30px auto;
    }

    h2 {
        color: #d63384;
        text-align: center;
        margin-bottom: 20px;
    }

    input {
        width: 100%;
        padding: 10px;
        margin-bottom: 10px;
        border-radius: 8px;
        border: 1px solid #ddd;
    }

    button {
        width: 100%;
        padding: 10px;
        background: #ff69b4;
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: bold;
        transition: 0.3s;
    }

        button:hover {
            background: #ff1493;
        }

    .btn-link {
        text-decoration: none;
        margin-right: 10px;
        font-weight: bold;
    }

    .edit {
        color: #6f42c1;
    }

    .delete {
        color: #dc3545;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
        background: white;
        border-radius: 12px;
        overflow: hidden;
    }

    th {
        background: #ffd6e8;
        padding: 10px;
    }

    td {
        padding: 10px;
        border-bottom: 1px solid #eee;
    }

    tr:hover {
        background: #fff5fa;
    }

    .badge {
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 12px;
    }

    .in {
        background: #d4edda;
        color: #155724;
    }

    .out {
        background: #f8d7da;
        color: #721c24;
    }
</style>

<div class="container">
    <h2 class="title">👤 Usuarios</h2>

    <a href="/User/Create" class="btn-add">+ Nuevo Usuario</a>

    <table>
        <tr>
            <th>ID</th>
            <th>Usuario</th>
            <th>Acciones</th>
        </tr>

        @foreach (var u in Model)
        {
            <tr>
                <td>@u.Id</td>
                <td>@u.Username</td>
                <td>
                    <a href="/User/Edit/@u.Id" class="btn-edit">Editar</a>
                    <a href="/User/Delete/@u.Id" class="btn-delete">Eliminar</a>
                </td>
            </tr>
        }
    </table>
</div>