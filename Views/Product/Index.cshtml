@model List<CrudApp.Models.Product>

<style>
    body {
        background: #fff0f5;
        font-family: 'Segoe UI', sans-serif;
    }

    .card {
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        width: 90%;
        margin: 30px auto;
    }

    h2 {
        color: #d63384;
        text-align: center;
        margin-bottom: 20px;
    }

    input {
        width: 100%;
        padding: 10px;
        margin-bottom: 10px;
        border-radius: 8px;
        border: 1px solid #ddd;
    }

    button {
        width: 100%;
        padding: 10px;
        background: #ff69b4;
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: bold;
        transition: 0.3s;
    }

        button:hover {
            background: #ff1493;
        }

    .btn-link {
        text-decoration: none;
        margin-right: 10px;
        font-weight: bold;
    }

    .edit {
        color: #6f42c1;
    }

    .delete {
        color: #dc3545;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
        background: white;
        border-radius: 12px;
        overflow: hidden;
    }

    th {
        background: #ffd6e8;
        padding: 10px;
    }

    td {
        padding: 10px;
        border-bottom: 1px solid #eee;
    }

    tr:hover {
        background: #fff5fa;
    }

    .badge {
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 12px;
    }

    .in {
        background: #d4edda;
        color: #155724;
    }

    .out {
        background: #f8d7da;
        color: #721c24;
    }
</style>

<h2>💄 Inventario de Cosméticos</h2>

<a href="/Product/Create">+ Nuevo Producto</a>

<table border="1" cellpadding="10">
    <tr>
        <th>Nombre</th>
        <th>Marca</th>
        <th>Categoría</th>
        <th>Tono</th>
        <th>Precio</th>
        <th>Cantidad</th>
        <th>Expira</th>
        <th>Acciones</th>
    </tr>

    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Name</td>
            <td>@p.Brand</td>
            <td>@p.Category</td>
            <td>@p.Shade</td>
            <td>$@p.Price</td>
            <td>@p.Quantity</td>
            <td>@p.ExpirationDate.ToShortDateString()</td>
            <td>
                <a href="/Product/Edit/@p.Id">✏️ Editar</a>
                <a href="/Product/Delete/@p.Id">🗑 Eliminar</a>
            </td>
        </tr>
    }
</table>